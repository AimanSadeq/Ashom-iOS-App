{
  "name": "vifm-gcc-financial-analysis",
  "version": "1.0.0",
  "description": "VIFM GCC Financial Analysis App - Complete fundamental analysis platform for GCC capital markets",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "nodemon server/index.js",
    "build": "cd frontend && npm install && CI=false npm run build",
    "init-db": "node server/initDatabase.js",
    "seed-db": "node server/seedDatabase.js",
    "lint": "eslint server/**/*.js",
    "lint:fix": "eslint server/**/*.js --fix",
    "test": "echo \"Error: no test specified\" && exit 1",
    "ios:sync": "npx cap sync ios",
    "ios:open": "npx cap open ios",
    "ios:run": "npx cap run ios"
  },
  "keywords": [
    "finance",
    "gcc",
    "analysis",
    "stock",
    "market"
  ],
  "author": "VIFM",
  "license": "ISC",
